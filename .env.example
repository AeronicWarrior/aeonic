# Aeonic Gateway — environment configuration
# Copy this to .env and fill in your keys

# ── Server ────────────────────────────────────────────────
AEONIC_HOST=0.0.0.0
AEONIC_PORT=8080

# ── Provider API keys ─────────────────────────────────────
# At least one provider must be configured to start routing

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (local models) ─────────────────────────────────
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434

# ── Logging ───────────────────────────────────────────────
# Options: error, warn, info, debug, trace
RUST_LOG=info,aeonic=debug
